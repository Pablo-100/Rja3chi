rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reports collection
    match /reports/{reportId} {
      allow read, write: if true;
    }

    // Custom districts collection
    match /customDistricts/{customDistrictId} {
      allow read, write: if true;
    }

    // STEG Notices collection
    match /stegNotices/{noticeId} {
      allow read, write: if true;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
